FROM rust:1-bookworm AS builder
WORKDIR /app
COPY . .
RUN cargo build --release -p ham-sync-server

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=builder /app/target/release/ham-sync-server /usr/local/bin/ham-sync-server
ENV HAM_SYNC_SERVER_BIND=0.0.0.0:9740
ENV HAM_SYNC_PUBLIC_URL=http://localhost:9740
ENV HAM_SYNC_SERVICE_MODE=self_hosted
EXPOSE 9740
CMD ["ham-sync-server"]
